# Thoth Docker Configuration
# Copy this to .env and adjust paths/settings for your system

# Host Ollama Connection
# Use http://host.docker.internal:11434 on Docker Desktop (Mac/Windows)
# Use http://localhost:11434 on Linux with --network=host
# Use http://<host-ip>:11434 on Linux/Mac when running Ollama on another machine
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Thoth Server Configuration
THOTH_PORT=8080

# Volume Mount Paths
# These determine where Thoth data and workspace are stored on your host
#
# ⚠️  DISK SPACE WARNING: Thoth memory grows 1-3 GB per week of active use.
#     After 2-3 weeks of use, thoth-data alone can exceed 10 GB.
#
# RECOMMENDATION: Use an external drive for these paths if available.
# Run ./scripts/disk-check.sh to detect drives and get a recommendation.
#
# On macOS/Windows Docker Desktop: use absolute paths or relative to docker-compose.yml
# On Linux: use absolute paths for bind mounts
#
# Examples:
#   macOS (external SSD):   /Volumes/ExternalSSD/thoth-data
#   macOS (system drive):   /Users/username/thoth-data
#   Linux (external):       /mnt/external/thoth-data
#   Linux (home):           /home/username/thoth-data
#   Windows (external D:):  D:\thoth-data
#   Windows (home):         C:\Users\username\thoth-data
THOTH_DATA_DIR=./thoth-data
THOTH_WORKSPACE_DIR=./thoth-workspace

# Container Restart Policy
# Options: no, always, unless-stopped, on-failure
RESTART_POLICY=unless-stopped

# ============================================================================
# OPTIONAL: Cloud LLM Provider Setup (if no local LLM available)
# ============================================================================
# Uncomment and configure if you want to use OpenRouter instead of Ollama
# See OPENROUTER_SETUP.md for detailed guide

# OpenRouter Configuration (Cloud-based, Recommended: $5+ credits)
# Sign up at https://openrouter.ai and add credit card + $5 minimum credit
# OPENROUTER_API_KEY=sk-or-your-actual-key-here
# THOTH_LLM_PROVIDER=openrouter
# THOTH_LLM_MODEL=anthropic/claude-3-haiku  # Cheap, good quality

# OpenRouter Free Routing (Testing only, very limited/slow)
# Same API key as above, but uses free models
# ⚠️  Only for testing - data may be logged - NOT for private data
# OPENROUTER_API_KEY=sk-or-your-actual-key-here
# THOTH_LLM_PROVIDER=openrouter
# THOTH_LLM_MODEL=openrouter/openrouter:free

# Alternative: Use OpenAI API directly
# OPENAI_API_KEY=sk-your-openai-key-here
# THOTH_LLM_PROVIDER=openai
# THOTH_LLM_MODEL=gpt-4-turbo

# Alternative: Use Anthropic Claude API directly
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# THOTH_LLM_PROVIDER=anthropic
# THOTH_LLM_MODEL=claude-3-haiku-20240307

# Alternative: OpenAI ChatGPT Plus ($20/month, if still available)
# ⚠️  As of 2026-05-25, ChatGPT Plus includes API access without separate credits
# ⚠️  This offering may change or be discontinued - verify at https://openai.com
# Requires: ChatGPT Plus subscription
# OPENAI_API_KEY=sk-your-chatgpt-plus-key
# THOTH_LLM_PROVIDER=openai
# THOTH_LLM_MODEL=gpt-4-turbo

# Note on Privacy:
# - Free cloud models (e.g., OpenRouter free tier) may log your data for training
# - Paid models typically have better privacy protections
# - See OPENROUTER_SETUP.md for privacy considerations and cost estimates
