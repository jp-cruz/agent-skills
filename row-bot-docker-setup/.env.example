# Row-Bot Docker Configuration
# Copy this to .env and adjust paths/settings for your system

# Host Ollama Connection
# Use http://host.docker.internal:11434 on Docker Desktop (Mac/Windows)
# Use http://localhost:11434 on Linux with --network=host
# Use http://<host-ip>:11434 on Linux/Mac when running Ollama on another machine
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Row-Bot Server Configuration
ROWBOT_PORT=8080

# Row-Bot Network Binding
# 127.0.0.1 (DEFAULT - most secure)
#   → Localhost only, no network access
#   → Only accessible from this computer
#
# 0.0.0.0 (Local Area Network / LAN)
#   → Listen on all local network interfaces
#   → Accessible from any device on your Local Area Network:
#     - WiFi devices
#     - Wired (Ethernet) devices
#     - Any device on same local network
#   → ASSUMES: Router/firewall is enabled and blocking external access
#   → To verify: Run ./health-check.sh to check firewall status
#   → For internet access: Use Cloudflare Tunnel or Tailscale (see NETWORK_SETUP.md)
#
# ⚠️  FIREWALL ASSUMPTION
# This setup assumes you have an active firewall that blocks internet access to port 8080.
# Most modern routers and operating systems have firewalls enabled by default.
# If you have disabled your firewall, LAN binding may be exposed to the internet.
# Always verify with: ./health-check.sh
#
# See references/NETWORK_SETUP.md for security guidance
ROWBOT_BIND=127.0.0.1

# Docker Volumes
# This setup uses pure Docker volumes (not host bind mounts) for stability and portability.
# Volumes are stored in Docker's standard location (/var/lib/docker/volumes/) and work
# identically on any Docker host (macOS, Linux, Windows).
#
# ⚠️  DISK SPACE WARNING: Row-Bot memory grows 1-3 GB per week of active use.
#     After 2-3 weeks, rowbot-data can exceed 10 GB.
#
# To inspect volume location on your system:
#   docker volume inspect row-bot-docker-setup_rowbot-data
#
# To back up volumes:
#   docker run --rm -v row-bot-docker-setup_rowbot-data:/data \
#     -v ./backups:/backup alpine tar czf /backup/rowbot-data-$(date +%Y%m%d).tar.gz -C /data .
#
# NOTE: ROWBOT_DATA_DIR and ROWBOT_WORKSPACE_DIR below are DEPRECATED (pre-v0.5.0 bind mounts)
# They are not used in v0.5.0+ which uses pure Docker volumes. Keep them for reference only.
ROWBOT_DATA_DIR=./rowbot-data
ROWBOT_WORKSPACE_DIR=./rowbot-workspace

# Container Restart Policy
# Options: no, always, unless-stopped, on-failure
RESTART_POLICY=unless-stopped

# ============================================================================
# OPTIONAL: Cloud LLM Provider Setup (if no local LLM available)
# ============================================================================
# Uncomment and configure if you want to use OpenRouter instead of Ollama
# See OPENROUTER_SETUP.md for detailed guide

# OpenRouter Configuration (Cloud-based, Recommended: $5+ credits)
# Sign up at https://openrouter.ai and add credit card + $5 minimum credit
# OPENROUTER_API_KEY=sk-or-your-actual-key-here
# ROWBOT_LLM_PROVIDER=openrouter
# ROWBOT_LLM_MODEL=anthropic/claude-3-haiku  # Cheap, good quality

# Alternative: Use OpenAI API directly
# OPENAI_API_KEY=sk-your-openai-key-here
# ROWBOT_LLM_PROVIDER=openai
# ROWBOT_LLM_MODEL=gpt-4-turbo

# Alternative: Use Anthropic Claude API directly
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ROWBOT_LLM_PROVIDER=anthropic
# ROWBOT_LLM_MODEL=claude-3-haiku-20240307

# Note on Privacy:
# - Free cloud models (e.g., OpenRouter free tier) may log your data for training
# - Paid models typically have better privacy protections
# - See OPENROUTER_SETUP.md for privacy considerations and cost estimates
