{
  "name": "thoth-docker-setup",
  "version": "0.5.0",
  "category": "deployment",
  "description": "Production-ready Docker Compose setup for Thoth with cross-platform support (macOS, Windows, Linux)",
  "author": "jp@legionforge.org",
  "license": "MIT",
  "repository": "https://github.com/jp-cruz/agent-skills",
  "keywords": [
    "thoth",
    "docker",
    "docker-compose",
    "deployment",
    "cross-platform",
    "ollama",
    "container"
  ],
  "requirements": {
    "docker": "20.10+",
    "docker-compose": "1.29+",
    "ollama": "any",
    "disk-space": "2GB",
    "platforms": [
      "macos-intel",
      "macos-arm64",
      "windows-wsl2",
      "linux"
    ]
  },
  "files": {
    "docker/Dockerfile": "Container image definition (Python 3.11 + Thoth)",
    "docker/docker-compose.yml": "Service orchestration with environment variable support",
    ".env.example": "Configuration template with platform-specific examples",
    ".dockerignore": "Build context optimization",
    ".gitignore": "Git ignore patterns",
    "setup.sh": "macOS/Linux automated setup and validation",
    "setup.bat": "Windows automated setup and validation",
    "README.md": "Complete setup guide with troubleshooting",
    "CLAUDE.md": "Developer guide for future iterations",
    "SKILL.md": "Skill overview and usage documentation",
    "UTILITIES_ANALYSIS.md": "Detailed analysis of included utilities",
    "skill-manifest.json": "This file"
  },
  "features": [
    "Fully parameterized configuration",
    "Cross-platform support (macOS, Windows, Linux)",
    "Automated setup validation",
    "Persistent data volumes",
    "Non-root user execution",
    "Ollama integration",
    "Comprehensive documentation",
    "Troubleshooting guides",
    "Multi-machine deployment support"
  ],
  "included-utilities": {
    "nano": "User-friendly text editor",
    "vim-tiny": "Lightweight Vi implementation",
    "jq": "JSON processor for API debugging",
    "less": "File pager for logs",
    "file": "File type identification",
    "tree": "Directory structure visualization",
    "unzip": "Archive extraction"
  },
  "quick-start": {
    "setup-macos-linux": [
      "./setup.sh",
      "vim .env  # customize if needed",
      "docker-compose up -d"
    ],
    "setup-windows": [
      "setup.bat",
      "notepad .env",
      "docker-compose up -d"
    ],
    "access": "http://localhost:8080"
  },
  "environment-variables": {
    "THOTH_PORT": {
      "default": "8080",
      "description": "Container port for Thoth server"
    },
    "THOTH_DATA_DIR": {
      "default": "./thoth-data",
      "description": "Host path for application data persistence"
    },
    "THOTH_WORKSPACE_DIR": {
      "default": "./thoth-workspace",
      "description": "Host path for workspace files"
    },
    "OLLAMA_BASE_URL": {
      "default": "http://host.docker.internal:11434",
      "description": "Ollama API endpoint (auto-detected per platform)",
      "macos": "http://host.docker.internal:11434",
      "windows": "http://host.docker.internal:11434",
      "linux": "http://localhost:11434 or http://<host-ip>:11434"
    },
    "RESTART_POLICY": {
      "default": "unless-stopped",
      "description": "Docker restart policy"
    }
  },
  "commands": {
    "setup": "./setup.sh (macOS/Linux) or setup.bat (Windows)",
    "start": "docker-compose up -d",
    "stop": "docker-compose stop",
    "logs": "docker-compose logs -f",
    "shell": "docker-compose exec thoth bash",
    "edit-config": "docker-compose exec thoth nano /home/thoth/.thoth/config.yaml",
    "test-ollama": "docker-compose exec thoth curl http://host.docker.internal:11434/api/tags | jq '.'",
    "backup": "tar -czf thoth-backup.tar.gz $(grep THOTH_DATA_DIR .env | cut -d= -f2) $(grep THOTH_WORKSPACE_DIR .env | cut -d= -f2)"
  },
  "testing": {
    "platforms-tested": [
      "macOS 13+ (Intel & Apple Silicon)",
      "Windows 11 (WSL 2)",
      "Linux (Ubuntu 22.04+, CentOS Stream 9)"
    ],
    "checklist": [
      "Setup script completes without errors",
      "docker-compose builds successfully",
      "Container starts and runs",
      "Thoth accessible at configured port",
      "Ollama connectivity works",
      "Data persists across restarts",
      "All utilities accessible to thoth user",
      "jq can parse Ollama API responses"
    ]
  },
  "troubleshooting": {
    "port-conflict": "Change THOTH_PORT in .env",
    "ollama-not-found": "Ensure Ollama is running and reachable",
    "volume-permissions": "Run: chmod 755 $(grep THOTH_DATA_DIR .env | cut -d= -f2)",
    "container-fails": "Run: docker-compose logs thoth"
  },
  "future-enhancements": [
    "Multi-stage Dockerfile for smaller images",
    "Docker Buildkit support",
    "Health checks",
    "Kubernetes manifests",
    "GitHub Actions CI/CD",
    "Pre-built Docker Hub images"
  ],
  "related-skills": [
    "ollama-setup",
    "docker-basics",
    "container-security"
  ]
}
